---
import CryptoControls from '../components/CryptoControls.vue';
import CryptoVisualizer from '../components/CryptoVisualizer.svelte';
import Layout from '../layouts/Layout.astro';

type Market = {
	id: string;
	displayName: string;
};

const fallbackMarkets: Market[] = [
	{ id: 'BTC-USD', displayName: 'Bitcoin / USD' },
	{ id: 'ETH-USD', displayName: 'Ethereum / USD' },
	{ id: 'SOL-USD', displayName: 'Solana / USD' },
	{ id: 'LTC-USD', displayName: 'Litecoin / USD' },
	{ id: 'ADA-USD', displayName: 'Cardano / USD' },
	{ id: 'DOGE-USD', displayName: 'Dogecoin / USD' },
	{ id: 'AVAX-USD', displayName: 'Avalanche / USD' },
	{ id: 'LINK-USD', displayName: 'Chainlink / USD' },
	{ id: 'DOT-USD', displayName: 'Polkadot / USD' },
	{ id: 'BCH-USD', displayName: 'Bitcoin Cash / USD' },
];

let markets = fallbackMarkets;
let usingFallbackMarkets = false;
let apiError = false;

try {
	const response = await fetch('https://api.exchange.coinbase.com/products');
	if (!response.ok) throw new Error('No fue posible obtener los mercados');

	const products = await response.json();
	const available = new Map(
		products
			.filter((product: any) => product.quote_currency === 'USD' && product.status === 'online')
			.map((product: any) => [product.id, product.display_name]),
	);

	const availableMarkets = fallbackMarkets.filter((market) => available.has(market.id));
	if (availableMarkets.length > 0) {
		markets = availableMarkets;
	} else {
		markets = fallbackMarkets;
		usingFallbackMarkets = true;
	}
} catch {
	markets = fallbackMarkets;
	usingFallbackMarkets = true;
	apiError = true;
}
---

<Layout>
	<div class="relative overflow-hidden">
		<div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-72 bg-[radial-gradient(circle_at_top,_rgba(99,102,241,0.16),_transparent_55%)]"></div>

		<header class="mx-auto flex w-full max-w-[1180px] flex-col gap-6 px-4 pb-6 pt-10 lg:flex-row lg:items-end lg:justify-between lg:pt-12">
			<div class="space-y-2">
				<p class="text-xs font-extrabold uppercase tracking-[0.24em] text-indigo-600">Dashboard Astro</p>
				<h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Criptont</h1>
			</div>
			<p class="max-w-xl text-sm leading-6 text-slate-500 lg:max-w-md lg:text-right">
				Precios de Coinbase Exchange con actualización cada 5 segundos.
			</p>
		</header>

		<main class="mx-auto grid w-full max-w-[1180px] gap-5 px-4 pb-8 lg:grid-cols-[minmax(280px,0.82fr)_minmax(0,1.18fr)]">
			{apiError ? (
				<div class="col-span-full rounded-2xl border border-red-200 bg-red-100 px-4 py-4 text-sm font-medium text-red-800 shadow-sm">
					Atención: Mostrando mercados de respaldo debido a un problema de conexión con la API de Coinbase.
				</div>
			) : null}

			<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_12px_35px_rgba(25,38,68,0.07)]" aria-labelledby="controls-title">
				<h2 id="controls-title" class="text-lg font-semibold tracking-tight text-slate-950">Configuración</h2>
				<p class="mt-2 text-sm leading-6 text-slate-500">Selecciona el mercado que quieres monitorear.</p>
				<CryptoControls client:load {markets} initialProductId="BTC-USD" />
			</section>

			<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_12px_35px_rgba(25,38,68,0.07)]" aria-labelledby="viewer-title">
				<h2 id="viewer-title" class="text-lg font-semibold tracking-tight text-slate-950">Mercado en vivo</h2>
				<CryptoVisualizer client:visible initialProductId="BTC-USD" />
			</section>
		</main>

		<footer class="mx-auto w-full max-w-[1180px] px-4 pb-10 pt-2 text-center text-sm text-slate-500">
			Datos públicos de Coinbase Exchange · Astro + Vue + Svelte
		</footer>
	</div>
</Layout>
